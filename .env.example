PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Odoo 17
ODOO_URL=your_odoo_host:port
ODOO_DB=your_db
ODOO_USER=admin@example.com
ODOO_PASSWORD=your_password

# Van Frontend database
PG_HOST=your_db_host
PG_PORT=5432
PG_USER=your_db_user
PG_PASSWORD=your_db_password
PG_DB=your_db_name

# JWT
JWT_SECRET=change_me_in_prod
JWT_EXPIRES_IN=8h
REFRESH_SECRET=change_me_refresh
REFRESH_EXPIRES_IN=7d

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,https://your-app.com

# SQLite
DB_PATH=./data/vansale.db

# Redis (required for Bull queue)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100